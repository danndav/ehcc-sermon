  "main": "dist/index.js",
  "name": "ehcc-plus-api",
  "private": true,
  "resolutions": {
    "semver": "7.6.0"
  },
  "scripts": {
    "build": "tsc --watch false",
    "db:docker": "echo 'Starting DB' && docker rm -fv ehcc-postgres && docker run --rm --name ehcc-postgres -e POSTGRES_PASSWORD=password -e POSTGRES_DB=ehcc -e POSTGRES_USER=ehcc -p 5577:5432 -d postgres:16-alpine",
    "db:migrations-server": "TYPEORM_MIGRATIONS='src/aop/db/migrations/**/*.ts' TYPEORM_DRIVER_EXTRA='{ \"ssl\": false }' TYPEORM_URL=\"postgres://e2e:${CI_POSTGRES_PASSWORD:-3b628d538f8705}@${CI_POSTGRES_HOST:-localhost}:${CI_POSTGRES_PORT:-5555}/${CI_POSTGRES_DB:-e2e}\" yarn run typeorm migration:run",
    "db:migrations": "TYPEORM_MIGRATIONS='src/aop/db/migrations/**/*.ts' TYPEORM_DRIVER_EXTRA='{ \"ssl\": false }' TYPEORM_URL=\"postgres://ehcc:password@${CI_TRUVALA_POSTGRES_ALIAS:-localhost}:${CI_POSTGRES_DEFAULT_PORT:-5577}/ehcc\" yarn run typeorm-ts-node-commonjs migration:run -d ormconfig.ts",
    "db:populate": "echo \"Populating schema\" && yarn run db:migrations && yarn run db:seed",
    "db:seed": "TYPEORM_MIGRATIONS='src/aop/db/seed/**/*.ts' TYPEORM_DRIVER_EXTRA='{ \"ssl\": false }' TYPEORM_URL=\"postgres://ehcc:password@${CI_TRUVALA_POSTGRES_ALIAS:-localhost}:${CI_POSTGRES_DEFAULT_PORT:-5577}/ehcc\"",
    "db:start": "yarn run db:stop && echo 'Starting DB with seed' && yarn run db:docker && wait-on tcp:${CI_POSTGRES_DEFAULT_PORT:-5577} -t 300000 -l && sleep 5 && yarn run db:populate",
    "db:stop": "docker kill ehcc-postgres || true",
    "lint": "eslint src --fix",
    "lint:to-file": "eslint src --cache --cache-strategy content -f json -o eslint-report.json",
    "lint:print": "node -p \"require('./node_modules/eslint/lib/cli-engine/formatters/stylish.js')(require('./eslint-report.json'))\"",
    "prettier": "prettier --write",
    "scan": "yarn build && yarn eslint --ext ts,tsx,js,js src && yarn prettier && yarn test",
    "start": "yarn serverless offline start --noTimeout --stage local --noPrependStageInUrl",
    "start:ci": "TYPEORM_URL=\"postgres://preppod:password@${CI_PREPPOD_POSTGRES_ALIAS:-localhost}:${CI_POSTGRES_DEFAULT_PORT:-5577}/preppod\" yarn serverless offline start --noTimeout --stage ci --noPrependStageInUrl",
    "start:local": "serverless offline start --noTimeout --stage local --noPrependStageInUrl --reloadHandler",
    "stop": "kill -9 $(pgrep -f \"serverless offline\" | grep -v ^$$\\$) || true",
    "test": "yarn run test-unit",
    "test-ci": "yarn run test-unit-coverage",
    "test-unit": "vitest",
    "test-unit-coverage": "vitest --coverage",
    "test-unit-coverage-ui": "vitest --coverage --ui",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:generate": "yarn run typeorm migration:generate src/aop/db/migrations/UNDEFINED",
    "typeorm:revert": "yarn run typeorm migration:revert",
    "typeorm:run": "yarn run typeorm migration:run",
    "typeorm:show": "yarn run typeorm migration:show || true",
    "jaeger:local": "docker run --rm -e COLLECTOR_ZIPKIN_HOST_PORT=:9411 -p 16686:16686 -p 4317:4317 -p 4318:4318 -p 9411:9411 jaegertracing/all-in-one:latest",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "typeorm:remote:dev": "TYPEORM_MIGRATIONS='src/aop/db/migrations/**/*.ts' TYPEORM_DRIVER_EXTRA='{\"ssl\":{\"rejectUnauthorized\":false,\"requestCert\":true}}' TYPEORM_URL=\"${TYPEORM_URL}\" yarn run typeorm-ts-node-commonjs migration:run -d ormconfig.ts",
    "typeorm:remote:prod": "TYPEORM_MIGRATIONS='src/aop/db/migrations/**/*.ts' TYPEORM_URL=\"${TYPEORM_URL}\" yarn run typeorm-ts-node-commonjs migration:run -d ormconfig.ts",
    "typeorm:remote:revert:dev": "TYPEORM_MIGRATIONS='src/aop/db/migrations/**/*.ts' TYPEORM_URL=\"${TYPEORM_URL}\" yarn run typeorm-ts-node-commonjs migration:revert -d ormconfig.ts",
    "typeorm:remote:dev:ci": "TYPEORM_MIGRATIONS='src/aop/db/migrations/**/*.ts' TYPEORM_DRIVER_EXTRA='{\"ssl\":{\"rejectUnauthorized\":false}}' TYPEORM_URL=\"${TYPEORM_URL}\" yarn run typeorm-ts-node-commonjs migration:run -d ormconfig.ts"
  },
  "version": "1.0.0",
  "packageManager": "yarn@4.4.1"
}
